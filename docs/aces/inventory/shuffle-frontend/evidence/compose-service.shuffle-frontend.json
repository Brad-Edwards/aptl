{
  "profiles": [
    "soc"
  ],
  "image": "ghcr.io/shuffle/shuffle-frontend:latest",
  "container_name": "aptl-shuffle-frontend",
  "restart": "unless-stopped",
  "ports": [
    "3443:443",
    "3001:80"
  ],
  "environment": [
    "BACKEND_HOSTNAME=shuffle-backend"
  ],
  "volumes": [
    "./config/soc_certs/shuffle-frontend/server.pem:/etc/nginx/fullchain.cert.pem:ro",
    "./config/soc_certs/shuffle-frontend/server.key:/etc/nginx/privkey.pem:ro",
    "./config/soc_certs/lab-ca.pem:/etc/lab-ca/lab-ca.pem:ro"
  ],
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "curl -ksf https://localhost/ || exit 1"
    ],
    "interval": "30s",
    "timeout": "10s",
    "retries": 10,
    "start_period": "60s"
  },
  "deploy": {
    "resources": {
      "limits": {
        "memory": "256m"
      }
    }
  },
  "depends_on": [
    "shuffle-backend"
  ],
  "networks": {
    "aptl-security": {
      "ipv4_address": "172.20.0.21"
    }
  }
}
