{
  "profiles": [
    "soc"
  ],
  "image": "cassandra:4.1",
  "container_name": "aptl-thehive-cassandra",
  "restart": "unless-stopped",
  "environment": [
    "CASSANDRA_CLUSTER_NAME=thehive",
    "MAX_HEAP_SIZE=512M",
    "HEAP_NEWSIZE=128M"
  ],
  "volumes": [
    "thehive_cassandra_data:/var/lib/cassandra"
  ],
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "cqlsh -e 'describe cluster' || exit 1"
    ],
    "interval": "30s",
    "timeout": "10s",
    "retries": 15,
    "start_period": "300s"
  },
  "deploy": {
    "resources": {
      "limits": {
        "memory": "1g"
      }
    }
  },
  "networks": {
    "aptl-security": null
  }
}
