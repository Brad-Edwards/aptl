# APTL lab fixture credential for TheHive -> Cortex.
#
# This file is mounted only as a Docker Compose env_file for TheHive.
# scripts/cortex-apikey.sh creates the matching Cortex service-account key
# during seed-prime bootstrap. The value is intentionally deterministic so
# TheHive can be configured before Cortex's first-run user database exists.
TH_CORTEX_KEYS=aptlcortexlabapikey2026purple
