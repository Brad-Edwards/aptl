{
  "profiles": [
    "reverse"
  ],
  "build": {
    "context": "/home/atomik/src/aptl3/containers",
    "dockerfile": "reverse/Dockerfile"
  },
  "cap_add": [
    "SYS_NICE",
    "SYS_ADMIN",
    "SYS_RESOURCE"
  ],
  "cgroup": "host",
  "command": null,
  "container_name": "aptl-reverse",
  "deploy": {
    "resources": {
      "limits": {
        "memory": "2147483648"
      }
    },
    "placement": {}
  },
  "entrypoint": null,
  "environment": {
    "LABADMIN_SSH_KEY_FILE": "/keys/aptl_lab_key.pub",
    "SIEM_IP": "172.20.0.10"
  },
  "hostname": "reverse-host",
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "ss -tlnp | grep ':22' || exit 1"
    ],
    "timeout": "5s",
    "interval": "15s",
    "retries": 5,
    "start_period": "30s"
  },
  "networks": {
    "aptl-security": {
      "ipv4_address": "172.20.0.27"
    }
  },
  "ports": [
    {
      "mode": "ingress",
      "target": 22,
      "published": "2027",
      "protocol": "tcp"
    }
  ],
  "restart": "unless-stopped",
  "security_opt": [
    "seccomp:unconfined"
  ],
  "tmpfs": [
    "/run",
    "/run/lock",
    "/tmp"
  ],
  "volumes": [
    {
      "type": "bind",
      "source": "/sys/fs/cgroup",
      "target": "/sys/fs/cgroup",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl3/keys/aptl_lab_key.pub",
      "target": "/keys/aptl_lab_key.pub",
      "read_only": true,
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl3/config/lab-ssh/kali_pivot_key.pub",
      "target": "/keys/kali_pivot_key.pub",
      "read_only": true,
      "bind": {}
    },
    {
      "type": "volume",
      "source": "reverse_logs",
      "target": "/var/log",
      "volume": {}
    }
  ]
}
