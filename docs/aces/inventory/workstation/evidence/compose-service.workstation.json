{
  "profiles": [
    "enterprise"
  ],
  "build": {
    "context": "./containers",
    "dockerfile": "workstation/Dockerfile"
  },
  "container_name": "aptl-workstation",
  "hostname": "ws01.techvault.local",
  "restart": "unless-stopped",
  "networks": {
    "aptl-internal": {
      "ipv4_address": "172.20.2.40"
    }
  },
  "environment": [
    "SIEM_IP=172.20.2.30",
    "LABADMIN_SSH_KEY_FILE=/keys/aptl_lab_key.pub"
  ],
  "cap_add": [
    "SYS_NICE",
    "SYS_ADMIN",
    "SYS_RESOURCE"
  ],
  "cgroup": "host",
  "volumes": [
    "/sys/fs/cgroup:/sys/fs/cgroup:rw",
    "./keys:/keys:ro",
    "workstation_logs:/var/log"
  ],
  "tmpfs": [
    "/run",
    "/tmp"
  ],
  "security_opt": [
    "seccomp:unconfined"
  ],
  "mem_limit": "256m",
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "ss -tlnp | grep ':22' || exit 1"
    ],
    "interval": "15s",
    "timeout": "5s",
    "retries": 5,
    "start_period": "30s"
  },
  "depends_on": {
    "wazuh.manager": {
      "condition": "service_healthy"
    }
  }
}
