{
  "profiles": [
    "enterprise"
  ],
  "command": [
    "postgres",
    "-c",
    "logging_collector=on",
    "-c",
    "log_directory=pg_log",
    "-c",
    "log_filename=postgresql.log",
    "-c",
    "log_statement=all",
    "-c",
    "log_connections=on",
    "-c",
    "log_disconnections=on"
  ],
  "container_name": "aptl-db",
  "deploy": {
    "resources": {
      "limits": {
        "memory": "268435456"
      }
    },
    "placement": {}
  },
  "entrypoint": null,
  "environment": {
    "POSTGRES_DB": "techvault",
    "POSTGRES_PASSWORD": "techvault_db_pass",
    "POSTGRES_USER": "techvault"
  },
  "hostname": "db.techvault.local",
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "pg_isready -U techvault -d techvault"
    ],
    "timeout": "5s",
    "interval": "10s",
    "retries": 5,
    "start_period": "15s"
  },
  "image": "postgres:16-alpine",
  "networks": {
    "aptl-internal": {
      "ipv4_address": "172.20.2.11"
    }
  },
  "restart": "unless-stopped",
  "volumes": [
    {
      "type": "volume",
      "source": "db_data",
      "target": "/var/lib/postgresql/data",
      "volume": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl/containers/db/init",
      "target": "/docker-entrypoint-initdb.d",
      "read_only": true,
      "bind": {}
    }
  ]
}
