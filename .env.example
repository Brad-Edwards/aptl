# APTL Lab Credentials
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.
#
# IMPORTANT: Change all CHANGE_ME values before starting the lab.
# Do NOT use these example values in any environment.

# Wazuh Indexer / OpenSearch admin credentials
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_indexer_password

# Wazuh Dashboard internal user
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password

# Wazuh API credentials
API_USERNAME=wazuh-wui
API_PASSWORD=CHANGE_ME_api_password

# Wazuh cluster key
WAZUH_CLUSTER_KEY=CHANGE_ME_cluster_key

# Enterprise services
DB_PASSWORD=CHANGE_ME_db_password
AD_ADMIN_PASSWORD=CHANGE_ME_ad_admin_password

# MISP Threat Intelligence Platform
MISP_DB_PASSWORD=CHANGE_ME_misp_db_password
MISP_DB_ROOT_PASSWORD=CHANGE_ME_misp_db_root_password
MISP_ADMIN_PASSWORD=CHANGE_ME_misp_admin_password

# TheHive Case Management
THEHIVE_SECRET=CHANGE_ME_thehive_secret

# Shuffle SOAR
SHUFFLE_ADMIN_PASSWORD=CHANGE_ME_shuffle_admin_password
SHUFFLE_API_KEY=CHANGE_ME_shuffle_api_key
SHUFFLE_OPENSEARCH_PASSWORD=CHANGE_ME_shuffle_opensearch_password
