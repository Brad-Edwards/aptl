# APTL Lab Credentials
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be committed.
#
# IMPORTANT: Replace every CHANGE_ME value before running the lab.
# Use strong, unique passwords (20+ characters, mixed case/numbers/symbols).

# Wazuh Indexer / OpenSearch admin credentials
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_indexer_password

# Wazuh Dashboard internal user
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password

# Wazuh API credentials
API_USERNAME=wazuh-wui
API_PASSWORD=CHANGE_ME_api_password

# Wazuh cluster key
WAZUH_CLUSTER_KEY=CHANGE_ME_cluster_key

# Enterprise services
DB_PASSWORD=CHANGE_ME_db_password
AD_ADMIN_PASSWORD=CHANGE_ME_ad_password

# MISP
MISP_ADMIN_PASSWORD=CHANGE_ME_misp_password
MISP_ADMIN_KEY=CHANGE_ME_misp_api_key
MISP_DB_PASSWORD=CHANGE_ME_misp_db_password
MISP_ROOT_PASSWORD=CHANGE_ME_misp_root_password
MISP_REDIS_PASSWORD=CHANGE_ME_misp_redis_password

# TheHive
THEHIVE_SECRET=CHANGE_ME_thehive_secret

# Shuffle SOAR
SHUFFLE_ADMIN_PASSWORD=CHANGE_ME_shuffle_password
SHUFFLE_API_KEY=CHANGE_ME_shuffle_api_key
SHUFFLE_OPENSEARCH_PASSWORD=CHANGE_ME_shuffle_opensearch_password

# CTF flag signing key (used by scoring engine)
APTL_FLAG_KEY=CHANGE_ME_flag_signing_key

# Grafana (OTel observability stack)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
