{
  "profiles": [
    "soc"
  ],
  "image": "jasonish/suricata:7.0",
  "container_name": "aptl-suricata",
  "hostname": "suricata",
  "restart": "unless-stopped",
  "cap_add": [
    "NET_ADMIN",
    "NET_RAW",
    "SYS_NICE"
  ],
  "volumes": [
    "suricata_config_seed:/seed:ro",
    "suricata_logs:/var/log/suricata",
    "suricata_command_socket:/var/run/suricata",
    "suricata_misp_rules:/var/lib/suricata/rules/misp:rw"
  ],
  "entrypoint": [
    "/bin/sh",
    "-c",
    "set -e\nmkdir -p /etc/suricata/rules\ncp /seed/suricata.yaml /etc/suricata/suricata.yaml\ncp /seed/rules/local.rules /etc/suricata/rules/local.rules\nexec /docker-entrypoint.sh -c /etc/suricata/suricata.yaml --pcap\n"
  ],
  "deploy": {
    "resources": {
      "limits": {
        "memory": "1g"
      }
    }
  },
  "networks": {
    "aptl-dmz": {
      "ipv4_address": "172.20.1.50"
    },
    "aptl-internal": {
      "ipv4_address": "172.20.2.50"
    },
    "aptl-security": {
      "ipv4_address": "172.20.0.50"
    }
  }
}
