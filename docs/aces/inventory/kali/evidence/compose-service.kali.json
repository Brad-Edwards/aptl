{
  "profiles": [
    "kali"
  ],
  "build": {
    "context": "/home/atomik/src/aptl2/containers/kali",
    "dockerfile": "Dockerfile"
  },
  "cap_add": [
    "NET_RAW",
    "NET_ADMIN",
    "AUDIT_CONTROL",
    "AUDIT_WRITE",
    "SYS_PACCT"
  ],
  "command": null,
  "container_name": "aptl-kali",
  "deploy": {
    "resources": {
      "limits": {
        "memory": "1073741824"
      }
    },
    "placement": {}
  },
  "entrypoint": null,
  "environment": {
    "VICTIM_IP": "172.20.2.20"
  },
  "extra_hosts": [
    "DC.TECHVAULT.LOCAL=172.20.2.10",
    "TECHVAULT.LOCAL=172.20.2.10",
    "db.techvault.local=172.20.2.11",
    "dc.techvault.local=172.20.2.10",
    "files.techvault.local=172.20.2.12",
    "mail.techvault.local=172.20.1.21",
    "ns1.techvault.local=172.20.2.27",
    "techvault.local=172.20.2.10",
    "ws01.techvault.local=172.20.2.22"
  ],
  "hostname": "kali-redteam",
  "healthcheck": {
    "test": [
      "CMD",
      "/usr/local/bin/aptl-healthcheck.sh"
    ],
    "timeout": "5s",
    "interval": "15s",
    "retries": 5,
    "start_period": "30s"
  },
  "init": true,
  "networks": {
    "aptl-dmz": {
      "ipv4_address": "172.20.1.30"
    },
    "aptl-internal": {
      "ipv4_address": "172.20.2.35"
    },
    "aptl-redteam": {
      "ipv4_address": "172.20.4.30"
    }
  },
  "restart": "unless-stopped",
  "security_opt": [
    "seccomp:unconfined"
  ],
  "volumes": [
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/keys",
      "target": "/host-ssh-keys",
      "read_only": true,
      "bind": {}
    },
    {
      "type": "volume",
      "source": "kali_operations",
      "target": "/home/kali/operations",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "kali_captures",
      "target": "/var/log/aptl/captures",
      "volume": {}
    }
  ]
}
