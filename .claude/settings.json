{
  "permissions": {
    "allow": [
      "mcp__aptl-reverse__reverse_info",
      "mcp__aptl-soar__soar_get_execution",
      "mcp__aptl-case-mgmt__cases_update_case",
      "mcp__aptl-reverse__reverse_run_command",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git clone:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect_files.sh"
          }
        ]
      }
    ]
  }
}
