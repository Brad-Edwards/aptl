{
  "profiles": [
    "wazuh"
  ],
  "command": null,
  "container_name": "aptl-wazuh-manager",
  "depends_on": {
    "wazuh.indexer": {
      "condition": "service_healthy",
      "required": true
    }
  },
  "deploy": {
    "resources": {
      "limits": {
        "memory": "1073741824"
      }
    },
    "placement": {}
  },
  "entrypoint": [
    "/bin/bash",
    "-c",
    "cp /tmp/filebeat-override.yml /etc/filebeat/filebeat.yml && chown root:root /etc/filebeat/filebeat.yml && python3 /docker-entrypoint-initdb.d/patch-rule-path.py 2>/dev/null; exec /init"
  ],
  "environment": {
    "API_PASSWORD": "<REDACTED-API-PASSWORD>",
    "API_USERNAME": "wazuh-wui",
    "FILEBEAT_SSL_VERIFICATION_MODE": "full",
    "INDEXER_PASSWORD": "<REDACTED-INDEXER-PASSWORD>",
    "INDEXER_URL": "https://wazuh.indexer:9200",
    "INDEXER_USERNAME": "admin",
    "SSL_CERTIFICATE": "/etc/ssl/filebeat.pem",
    "SSL_CERTIFICATE_AUTHORITIES": "/etc/ssl/root-ca.pem",
    "SSL_KEY": "<REDACTED-SSL-KEY>"
  },
  "hostname": "wazuh.manager",
  "healthcheck": {
    "test": [
      "CMD-SHELL",
      "curl -ks https://localhost:55000 || exit 1"
    ],
    "timeout": "10s",
    "interval": "30s",
    "retries": 5,
    "start_period": "2m0s"
  },
  "image": "wazuh/wazuh-manager:4.12.0",
  "networks": {
    "aptl-dmz": {
      "ipv4_address": "172.20.1.10"
    },
    "aptl-internal": {
      "ipv4_address": "172.20.2.30"
    },
    "aptl-security": {
      "ipv4_address": "172.20.0.10"
    }
  },
  "ports": [
    {
      "mode": "ingress",
      "target": 1514,
      "published": "1514",
      "protocol": "tcp"
    },
    {
      "mode": "ingress",
      "target": 1515,
      "published": "1515",
      "protocol": "tcp"
    },
    {
      "mode": "ingress",
      "target": 514,
      "published": "514",
      "protocol": "udp"
    },
    {
      "mode": "ingress",
      "target": 55000,
      "published": "55000",
      "protocol": "tcp"
    }
  ],
  "restart": "always",
  "ulimits": {
    "memlock": {
      "soft": -1,
      "hard": -1
    },
    "nofile": {
      "soft": 655360,
      "hard": 655360
    }
  },
  "volumes": [
    {
      "type": "volume",
      "source": "wazuh_api_configuration",
      "target": "/var/ossec/api/configuration",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_etc",
      "target": "/var/ossec/etc",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_logs",
      "target": "/var/ossec/logs",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_queue",
      "target": "/var/ossec/queue",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_var_multigroups",
      "target": "/var/ossec/var/multigroups",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_integrations",
      "target": "/var/ossec/integrations",
      "volume": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/custom-shuffle",
      "target": "/var/ossec/integrations/custom-shuffle",
      "bind": {}
    },
    {
      "type": "volume",
      "source": "wazuh_active_response",
      "target": "/var/ossec/active-response/bin",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_agentless",
      "target": "/var/ossec/agentless",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "wazuh_wodles",
      "target": "/var/ossec/wodles",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "filebeat_etc",
      "target": "/etc/filebeat",
      "volume": {}
    },
    {
      "type": "volume",
      "source": "filebeat_var",
      "target": "/var/lib/filebeat",
      "volume": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/filebeat_wazuh_module.yml",
      "target": "/tmp/filebeat-override.yml",
      "read_only": true,
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_indexer_ssl_certs/root-ca-manager.pem",
      "target": "/etc/ssl/root-ca.pem",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_indexer_ssl_certs/wazuh.manager.pem",
      "target": "/etc/ssl/filebeat.pem",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_indexer_ssl_certs/wazuh.manager-key.pem",
      "target": "/etc/ssl/filebeat.key",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/.aptl/config/wazuh_cluster/wazuh_manager.conf",
      "target": "/wazuh-config-mount/etc/ossec.conf",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/falco_rules.xml",
      "target": "/var/ossec/etc/rules/falco_rules.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/samba_decoders.xml",
      "target": "/var/ossec/etc/decoders/samba_decoders.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/postgresql_decoders.xml",
      "target": "/var/ossec/etc/decoders/postgresql_decoders.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/ad_rules.xml",
      "target": "/var/ossec/etc/rules/ad_rules.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/webapp_rules.xml",
      "target": "/var/ossec/etc/rules/webapp_rules.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/suricata_rules.xml",
      "target": "/var/ossec/etc/rules/suricata_rules.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/database_rules.xml",
      "target": "/var/ossec/etc/rules/database_rules.xml",
      "bind": {}
    },
    {
      "type": "bind",
      "source": "/home/atomik/src/aptl2/config/wazuh_cluster/patch-rule-path.py",
      "target": "/docker-entrypoint-initdb.d/patch-rule-path.py",
      "read_only": true,
      "bind": {}
    }
  ]
}
