FROM python:3.12-slim

WORKDIR /app

# Install system deps for Docker CLI
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    curl -fsSL https://get.docker.com | sh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY pyproject.toml .
COPY src/ src/
RUN pip install --no-cache-dir ".[web]"

EXPOSE 8400

CMD ["uvicorn", "aptl.api.main:app", "--host", "0.0.0.0", "--port", "8400"]
